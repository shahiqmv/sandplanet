# Sand Planet — production environment (M8). Copy to `.env` on the droplet
# and fill in real values. NEVER commit the real .env.

# --- Domain (Caddy auto-HTTPS) ---
DOMAIN=app.sandplanet.mv

# --- Django core ---
DJANGO_DEBUG=0
# Generate once:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_long_random_secret
DJANGO_ALLOWED_HOSTS=app.sandplanet.mv
CSRF_TRUSTED_ORIGINS=https://app.sandplanet.mv
# Turn on only after HTTPS is confirmed working (locks browsers to HTTPS):
SECURE_HSTS_SECONDS=0
# PDFs must succeed in production:
PDF_REQUIRED=1

# --- Postgres (the db service) ---
POSTGRES_DB=sandplanet
POSTGRES_USER=sandplanet
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# POSTGRES_HOST is set to `db` by the compose file.

# --- File storage: DigitalOcean Spaces (S3-compatible) ---
S3_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=sandplanet

# --- First-run admin (used only when RUN_SEED=1) ---
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- Gunicorn (optional tuning) ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# --- Email (Zoho SMTP) — for new-user welcome emails ---
# Organization / hosted-domain Zoho accounts use smtppro.zoho.com (personal
# free accounts use smtp.zoho.com). Match your data region: .com / .eu / .in /
# .com.au etc. Port 465 + SSL. EMAIL_HOST_PASSWORD must be a Zoho
# *app-specific password* (Zoho → Security → App Passwords), not your login.
EMAIL_HOST=smtppro.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USE_TLS=0
EMAIL_HOST_USER=no-reply@sandplanet.mv
EMAIL_HOST_PASSWORD=CHANGE_ME_zoho_app_password
DEFAULT_FROM_EMAIL=Sand Planet <no-reply@sandplanet.mv>
# The login link placed in invite emails (your live app URL):
APP_BASE_URL=https://sandplanet.159.223.35.180.sslip.io

# --- SMS / WhatsApp alerts (Twilio) — optional ---
# Leave blank to keep the in-app bell only (no external messages sent).
# When set, a user with a mobile number and SMS opted in (Admin → Users) gets
# an SMS/WhatsApp whenever a document is waiting on them. After filling these,
# redeploy and use Admin → Users → "Send test" to confirm delivery.
#   1. Create a Twilio account, buy an SMS-capable number (or set up the
#      WhatsApp sender), and copy the Account SID + Auth Token from the console.
#   2. TWILIO_FROM is your Twilio number in +E.164 form (e.g. +12025550123),
#      or your approved WhatsApp sender number.
#   3. TWILIO_CHANNEL = sms (default) or whatsapp.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_CHANNEL=sms
